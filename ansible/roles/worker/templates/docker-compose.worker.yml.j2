# Managed by Ansible — Pi Swarm Worker
services:
  worker:
    image: pi-swarm:latest
    container_name: pi-swarm-worker
    restart: always
    ports:
      - "0.0.0.0:8000:8000"
    env_file:
      - /etc/pi-swarm/gitea.env
    environment:
      - GITEA_API_BASE_URL={{ gitea_api_base_url }}
      - ORCHESTRATOR_URL={{ orchestrator_url }}
      - SWARM_CONFIG_PATH=/app/config/swarm_config.yaml
      - AGENT_ID={{ worker_agent_id | default(inventory_hostname) }}
      - HF_MODEL={{ hf_model }}
      - WORKER_ADVERTISE_HOST={{ ansible_host }}
    volumes:
      - hf-cache:/root/.cache/huggingface
    mem_limit: {{ swarm_container_memory_limit | default('3584m') }}
    command:
      - python3
      - -m
      - uvicorn
      - src.worker.app:app
      - --host
      - "0.0.0.0"
      - --port
      - "8000"
      - --log-level
      - info

volumes:
  hf-cache:
